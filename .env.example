# Colony Environment Variables for Custom API
# This file is loaded by dotenv (DO NOT use 'export' keyword)

# Option 1: Use same endpoint for both LLM and embedder (shared)
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_API_KEY=your-api-key-here

# Option 2: Use different endpoints for LLM and embedder (override shared)
# LLM-specific (takes priority over OPENAI_BASE_URL)
# LLM_BASE_URL=https://api.example.com/v1
# LLM_API_KEY=your-llm-api-key

# Embedder-specific (takes priority over OPENAI_BASE_URL)
# EMBEDDER_BASE_URL=https://api.example.com/v1
# EMBEDDER_API_KEY=your-embedder-api-key

# Neo4j Configuration (optional)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GROUP_ID=your-discord-server-id
DISCORD_SESSION_CATEGORY=your-category-id
