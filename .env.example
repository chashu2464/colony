# Colony Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================================
# OpenAI API (Default)
# ============================================================
OPENAI_API_KEY=sk-...

# ============================================================
# Custom API Endpoints (Optional)
# ============================================================

# Custom LLM endpoint (OpenAI-compatible)
# Examples:
# - Ollama: http://localhost:11434/v1
# - LM Studio: http://localhost:1234/v1
# - Together AI: https://api.together.xyz/v1
# - Groq: https://api.groq.com/openai/v1
# - OpenRouter: https://openrouter.ai/api/v1
CUSTOM_LLM_BASE_URL=https://api.openai.com/v1
CUSTOM_LLM_API_KEY=

# Custom Embedder endpoint
CUSTOM_EMBEDDER_BASE_URL=https://api.openai.com/v1
CUSTOM_EMBEDDER_API_KEY=

# ============================================================
# Third-Party API Keys (Optional)
# ============================================================

# Together AI
TOGETHER_API_KEY=

# Groq
GROQ_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Cohere (for reranker)
COHERE_API_KEY=

# ============================================================
# Azure OpenAI (Optional)
# ============================================================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ============================================================
# Cloudflare Workers AI (Optional)
# ============================================================
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ============================================================
# Vector Store Configuration
# ============================================================

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=  # For Qdrant Cloud
# QDRANT_URL=https://your-cluster.qdrant.io

# Pinecone (if using)
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=us-east-1

# ============================================================
# Graph Store Configuration (Optional)
# ============================================================

# Neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ============================================================
# Colony Configuration
# ============================================================

# Colony API endpoint (for skills)
COLONY_API=http://localhost:3001

# ============================================================
# Development Settings
# ============================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Log persistence
LOG_TO_FILE=true
LOG_DIR=logs

# Enable debug mode
DEBUG=false
